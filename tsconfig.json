{
  "compilerOptions": {
    "target": "ES2018",
    "module": "CommonJS",
    "declaration": true,
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "outDir": "./dist",
    "rootDir": "./lib",
    "lib": ["DOM", "ESNext"]
  },
  "include": ["lib/**/*"],
  "exclude": ["node_modules", "dist"]
}